<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.libconnect.gui.LoginController"
    styleClass="root-pane"
    prefWidth="900"
    prefHeight="600">

    <!-- ── CENTER: Login Card ───────────────────────────────────── -->
    <center>
        <VBox
            alignment="CENTER"
            spacing="20"
            maxWidth="420"
            styleClass="login-card"
            BorderPane.alignment="CENTER">

            <padding>
                <Insets top="48" right="48" bottom="48" left="48"/>
            </padding>

            <!-- App Title -->
            <Label
                text="LibConnect"
                styleClass="app-title"/>

            <Label
                text="Library Management System"
                styleClass="app-subtitle"/>

            <Separator/>

            <!-- Email Field -->
            <VBox spacing="6">
                <Label text="Email Address" styleClass="field-label"/>
                <TextField
                    fx:id="emailField"
                    promptText="Enter your email"
                    styleClass="input-field"/>
            </VBox>

            <!-- Password Field -->
            <VBox spacing="6">
                <Label text="Password" styleClass="field-label"/>
                <PasswordField
                    fx:id="passwordField"
                    promptText="Enter your password"
                    styleClass="input-field"/>
            </VBox>

            <!-- Error Label -->
            <Label
                fx:id="errorLabel"
                text=""
                styleClass="error-label"
                wrapText="true"
                maxWidth="320"/>

            <!-- Login Button -->
            <Button
                fx:id="loginButton"
                text="Login"
                onAction="#handleLogin"
                styleClass="btn-primary"
                maxWidth="Infinity"/>

            <HBox alignment="CENTER" spacing="12">

                <!-- Reset Button -->
                <Button
                    fx:id="resetButton"
                    text="Reset"
                    onAction="#handleReset"
                    styleClass="btn-secondary"/>

                <!-- Guest Button -->
                <Button
                    fx:id="guestButton"
                    text="Continue as Guest"
                    onAction="#handleGuestAccess"
                    styleClass="btn-ghost"/>

            </HBox>

            <Separator/>

            <!-- Footer -->
            <Label
                text="LibConnect v1.0  •  Academic Project"
                styleClass="footer-label"/>

        </VBox>
    </center>

</BorderPane>